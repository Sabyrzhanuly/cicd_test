{
  "name": "cicd-sandbox",
  "version": "0.1.0",
  "private": true,
  "description": "Тестовый проект: GitHub + Copilot Free + Telegram CI/CD",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "lint": "eslint src tests",
    "test": "node --test tests/*.test.js",
    "build": "node scripts/build.js",
    "ci": "npm run lint && npm run build",
    "test:telegram": "node scripts/test-telegram.js",
    "test:e2e": "playwright test",
    "test:e2e:ruleset": "playwright test e2e/ruleset-direct-push.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "branch:status": "node scripts/branch-status.js",
    "branch:status:md": "node scripts/branch-status.js --markdown --file BRANCH_STATUS.md"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "eslint": "^9.28.0"
  },
  "engines": {
    "node": ">=20"
  }
}
